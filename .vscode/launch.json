{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${fileWorkspaceFolder}",
      "env": {
        "PYTHONPATH": "${fileWorkspaceFolder}/src"
      }
    }
  ]
}
